# ── Operation mode ─────────────────────────────────────────────────────────
# "test"       → Binance Testnet and Ethereum Mainnet (builds txs, does NOT send)
# "production" → Binance Mainnet and Ethereum Mainnet (full execution)
OPERATION_MODE=test

# ── Binance Testnet credentials (used when OPERATION_MODE=test) ─────────────
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# ── Binance Mainnet credentials (used when OPERATION_MODE=production) ───────
BINANCE_API_KEY=your_mainnet_api_key_here
BINANCE_SECRET=your_mainnet_secret_here

# ── Ethereum / DEX ──────────────────────────────────────────────────────────
# Ethereum Mainnet RPC (Alchemy / Infura / etc.)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ETH_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_PROJECT_ID

# Sepolia testnet (for integration test only)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Hot wallet private key (0x-prefixed)
PRIVATE_KEY=your_private_key_here

# Uniswap V2 router (same for mainnet)
UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# Comma-separated Uniswap V2 pair addresses to track
# Example: ETH/USDT pair on Uniswap V2
POOL_ADDRESSES=0x0d4a11d5eeaac28ec3f61d100daf4d40471f1852

# ── DEX execution parameters ────────────────────────────────────────────────
GAS_LIMIT_SWAP=250000
GAS_LIMIT_APPROVAL=60000
SLIPPAGE_TOLERANCE_BPS=50
TX_DEADLINE_SECONDS=300

# ── Executor parameters ─────────────────────────────────────────────────────
LEG1_TIMEOUT=5
LEG2_TIMEOUT=60
MIN_FILL_RATIO=0.80
VAR_CONFIDENCE=0.95
VOL_PER_SQRT_SECOND=0.0002
USE_DEX_FIRST=true
MAX_RECOVERY_ATTEMPTS=2
UNWIND_TIMEOUT=30
UNWIND_SLIPPAGE_BPS=100

# ── Signal generator parameters ─────────────────────────────────────────────
SIGNAL_TTL_SECONDS=5
COOLDOWN_SECONDS=2
KELLY_FRACTION=0.25
MAX_POSITION_USD=10000
CEX_TAKER_BPS=10
DEX_SWAP_BPS=30
GAS_COST_USD=5

# ── Anvil fork (local development) ───────────────────────────────────────────────────
FORK_BLOCK=24842945
FORK_PORT=8545
FORK_ACCOUNTS=10
FORK_BALANCE=10000

# ── OpenAI (LLM anomaly advisor) ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
