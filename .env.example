# ── Operation mode ──────────────────────────────────────────────────────────
# "test"       → Binance Testnet and Arbitrum/Ethereum (dry-run, no real trades)
# "demo"       → Binance Demo Trading and Anvil fork of Arbitrum (realistic simulation)
# "production" → Binance Mainnet and Arbitrum One (live execution)
OPERATION_MODE=demo

# DRY_RUN: "true" = log signals but never execute trades (safe default)
# Can be set to "false" in production mode once you are ready to go live
DRY_RUN=true

# ── Network (DEX / on-chain) ─────────────────────────────────────────────────
# USE_ARBITRUM=true  → Arbitrum One (chain_id=42161, gas ~$0.01)
# USE_ARBITRUM=false → Ethereum Mainnet (chain_id=1, gas ~$5-$15)
USE_ARBITRUM=true

# Arbitrum One RPC (primary)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/ws

# Ethereum Mainnet RPC (fallback)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ETH_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_PROJECT_ID

# Sepolia testnet (for integration test only)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Hot wallet private key (0x-prefixed)
PRIVATE_KEY=your_private_key_here

# ── Contract addresses ───────────────────────────────────────────────────────
# Arbitrum One - Uniswap V2
UNISWAP_V2_ROUTER=0x4752ba5dbc23f44d87826276bf6fd6b1c372ad24
UNISWAP_V2_FACTORY=0xf1D7CC64Fb4452F05c498126312eBE29f30Fbcf9

# Comma-separated Uniswap V2 pair addresses to track
# ARB/USDC Uniswap V2 pool on Arbitrum One
POOL_ADDRESSES=0xd65ef54b1ff5d9a452b32ac0c304d1674f761061

# ── Binance credentials ──────────────────────────────────────────────────────
# Testnet (used when OPERATION_MODE=test)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# Demo (used when OPERATION_MODE=demo)
BINANCE_DEMO_API_KEY=your_demo_api_key_here
BINANCE_DEMO_SECRET=your_demo_secret_here

# Mainnet (used when OPERATION_MODE=production)
BINANCE_API_KEY=your_mainnet_api_key_here
BINANCE_SECRET=your_mainnet_secret_here

# ── Trading pair & Binance order filters ─────────────────────────────────────
TRADING_PAIR=ETH/USDC
MIN_NOTIONAL_USD=5.0
LOT_SIZE_STEP=0.0001
PRICE_TICK=0.01

# ── DEX execution ────────────────────────────────────────────────────────────
GAS_LIMIT_SWAP=500000
GAS_LIMIT_APPROVAL=100000
SLIPPAGE_TOLERANCE_BPS=50
TX_DEADLINE_SECONDS=300

# ── Executor parameters ──────────────────────────────────────────────────────
LEG1_TIMEOUT=5
LEG2_TIMEOUT=60
MIN_FILL_RATIO=0.80
VAR_CONFIDENCE=0.95
VOL_PER_SQRT_SECOND=0.0002
USE_DEX_FIRST=true
MAX_RECOVERY_ATTEMPTS=2
UNWIND_TIMEOUT=30
UNWIND_SLIPPAGE_BPS=100

# ── Risk management (soft limits, hard ceilings are in killswitch) ───────
INITIAL_CAPITAL=0.0
MAX_TRADE_USD=20.0
MAX_TRADE_PCT=0.20
MAX_POSITION_PER_TOKEN=30.0
MAX_OPEN_POSITIONS=1
MAX_LOSS_PER_TRADE=5.0
MAX_DAILY_LOSS=15.0
MAX_DRAWDOWN_PCT=0.20
MAX_TRADES_PER_HOUR=20
CONSECUTIVE_LOSS_LIMIT=3
MAX_SPREAD_BPS=500.0
MAX_SIGNAL_AGE_SECONDS=5.0

# ── Signal generator ─────────────────────────────────────────────────────────
SIGNAL_TTL_SECONDS=5
COOLDOWN_SECONDS=2
KELLY_FRACTION=0.25
MAX_POSITION_USD=10000
CEX_TAKER_BPS=10
DEX_SWAP_BPS=30
GAS_COST_USD=0.10

# ── Kill switch ───────────────────────────────────────────────────────────────
# Activate: touch /tmp/arb_bot_kill
# Deactivate: rm /tmp/arb_bot_kill
KILL_SWITCH_FILE=/tmp/arb_bot_kill
HEARTBEAT_FILE=/tmp/arb_bot_heartbeat

# ── WebSocket / real-time feed ──────────────────────────────────────────────
# Binance WebSocket endpoints
BINANCE_TESTNET_WS=wss://testnet.binance.vision/ws
BINANCE_TESTNET_REST=https://testnet.binance.vision
BINANCE_DEMO_WS_URL=wss://demo-stream.binance.com:9443/ws
BINANCE_DEMO_REST_URL=https://demo-api.binance.com
BINANCE_MAINNET_WS=wss://stream.binance.com:9443/ws
BINANCE_MAINNET_REST=https://api.binance.com

# DEX reserve polling interval (Arbitrum ~250ms blocks; 1s is safe)
DEX_POLL_INTERVAL_SECONDS=1.0
# Minimum DEX price change to trigger signal re-evaluation (bps)
DEX_MIN_CHANGE_BPS=0.1
# Maximum age of a CEX or DEX price before state is considered stale
PRICE_STALE_THRESHOLD_SECONDS=5.0

# WebSocket reconnect settings
WS_RECONNECT_DELAY_SECONDS=2
WS_MAX_RECONNECT_ATTEMPTS=10
WS_PING_INTERVAL_SECONDS=20

# ── Monitoring ────────────────────────────────────────────────────────────────
LOG_DIR=logs

# Discord webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: override the bot display name shown in Discord
DISCORD_BOT_USERNAME=ArbBot

# Optional: URL of an avatar image for the Discord bot messages
DISCORD_AVATAR_URL=https://omisoft.net/wp-content/uploads/2023/10/unnamed.png

# ── OpenAI (LLM anomaly advisor, optional) ──────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Anvil fork (demo mode) ────────────────────────────────────────────────
# For OPERATION_MODE=demo the bot connects its DEX leg to a local Anvil fork
# of Arbitrum Mainnet, which preserves real pool reserves while allowing
# unlimited test-token injection via Foundry cheatcodes.

#   make fork-arb   # Starts: anvil --fork-url $ARBITRUM_RPC_URL --port 8545
#   make fund-demo   # Funds DEMO_WALLET_ADDRESS with ARB, USDC, WETH
#   make run-demo   # Runs the full demo stack end-to-end

# RPC URL used by the bot in demo mode (points at the Anvil container)
ANVIL_RPC_URL=http://anvil:8545

# Arbitrum RPC used by Anvil itself to fork from
ANVIL_FORK_URL=https://arb1.arbitrum.io/rpc

# Wallet address to fund with test tokens in demo mode
DEMO_WALLET_ADDRESS=your_wallet_address_here

# Comma-separated list of tokens to fund in demo mode
DEMO_TOKENS=ARB,USDC

# ── Anvil fork (local development only) ───────────────────────────────────────────────
FORK_BLOCK=24842945
FORK_PORT=8545
FORK_ACCOUNTS=10
FORK_BALANCE=10000
